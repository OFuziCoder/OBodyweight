# CMake build dir — FetchContent deps (CommonLibSSE-NG, spdlog, rapidcsv) + intermediates.
# Hundreds of MB; regenerated by `cmake --preset release`. Never commit.
plugin/build/

# MSVC / CMake user files
plugin/out/
*.user
CMakeUserPresets.json

# Local dev/build scripts (environment-specific paths; kept on disk, not in the repo)
build.ps1
make_*.py

# Distribution simulator + abandoned config experiments (dev only, not part of the mod)
plugin/sim/
_disabled_cbpc_configs/

# Dev/inspection tools (Mutagen/Synthesis utilities) — environment-specific, NOT part of OBW; never publish.
tools/

# Temp / OS
*.tmp
Thumbs.db
desktop.ini

# Local release staging + archives (releases go to Nexus/GitHub Releases, not the repo)
dist/

# Editor workspace config (environment-specific)
.vscode/

# Compiled build outputs — reproducible from plugin/src (DLL via cmake) and Scripts/Source (pex via PapyrusCompiler).
# The release zip carries these; the repo stays source-only.
SKSE/Plugins/OBodyNGWeight.dll
Scripts/*.pex
